# Copia a .env y ajusta antes de producción
# cp .env.example .env

# === REQUERIDO ===
# Código de desbloqueo del sistema — sin él, el bot NO arranca ni vincula
SYSTEM_UNLOCK_CODE=
# Código del panel L2 (opcional; si no lo pones se usa el interno del sistema)
# BOT_L2_CODE=
ADMIN_PRIVILEGIADO=7571040521

# === VINCULACIÓN WHATSAPP (VPS) ===
# Número del bot sin + ni espacios. Ej: 5212281234567
WA_PHONE=5210000000000
# code = código 8 letras (ROTO en WA Web actual) | qr = escanear QR (recomendado)
LOGIN_MODE=qr

# === OPCIONAL ===
# Reintentos de reconexión si WhatsApp Web se cae (default: 5)
# MAX_RECONNECT=5
# NO fijar WA_WEB_VERSION salvo emergencia — por defecto usa WhatsApp Web en vivo
# WA_WEB_VERSION=2.3000.1042562325-alpha
# Reinicio diario para liberar RAM de Chrome (hora local 0-23; vacío = desactivado)
# DAILY_RESTART_HOUR=4
# Reporte automático al ADMIN_PRIVILEGIADO (horas; 0 = solo al conectar)
# FLEET_REPORT_HOURS=24
# Ignorar DMs que no sean comandos (ahorro de recursos)
# IGNORE_NON_COMMANDS=false
